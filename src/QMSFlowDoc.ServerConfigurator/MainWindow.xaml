<Window x:Class="QMSFlowDoc.ServerConfigurator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="QMSFlowDoc — Configurador del Servidor" Height="700" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E2E">
    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#FF89B4FA"/>
            <Setter Property="Margin" Value="0,10,0,6"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF313244"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="BorderBrush" Value="#FF45475A"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#FF45475A"/>
            <Setter Property="Foreground" Value="#FFCDD6F4"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderBrush" Value="#FF585B70"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <TabControl Background="#FF1E1E2E" Foreground="#FFCDD6F4" BorderBrush="#FF45475A">
            <!-- ═══ SQL Server Tab ═══ -->
            <TabItem Header="🗄️ SQL Server" Foreground="#FFCDD6F4">
                <StackPanel Margin="16">
                    <TextBlock Text="Configuración SQL Server Express" Style="{StaticResource SectionHeader}"/>
                    <Label Content="Instancia SQL Server:"/>
                    <TextBox x:Name="TxtSqlInstance" Text=".\SQLEXPRESS"/>
                    <Label Content="Nombre de Base de Datos:"/>
                    <TextBox x:Name="TxtDatabaseName" Text="QMSFlowDoc"/>
                    <CheckBox x:Name="ChkIntegratedSecurity" Content="Usar autenticación de Windows (Integrated Security)" IsChecked="True" Margin="0,8"/>
                    <Label Content="Usuario SQL (si no usa Windows Auth):"/>
                    <TextBox x:Name="TxtSqlUser"/>
                    <Label Content="Contraseña SQL:"/>
                    <PasswordBox x:Name="TxtSqlPassword" Background="#FF313244" Foreground="#FFCDD6F4" BorderBrush="#FF45475A" Padding="6,4"/>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button x:Name="BtnTestConnection" Content="🔌 Probar Conexión" Click="BtnTestConnection_Click" Margin="0,0,10,0"/>
                        <Button x:Name="BtnCreateDatabase" Content="🆕 Crear Base de Datos" Click="BtnCreateDatabase_Click" Margin="0,0,10,0"/>
                        <Button x:Name="BtnApplyMigrations" Content="📦 Aplicar Migraciones" Click="BtnApplyMigrations_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtSqlStatus" Foreground="#FFA6E3A1" Margin="0,10" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>

            <!-- ═══ Carpetas Tab ═══ -->
            <TabItem Header="📁 Carpetas" Foreground="#FFCDD6F4">
                <StackPanel Margin="16">
                    <TextBlock Text="Repositorio Documental Central" Style="{StaticResource SectionHeader}"/>
                    <Label Content="Carpeta raíz del repositorio:"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="📂" Click="BtnBrowseDocPath_Click" Width="40" Margin="4,0,0,0"/>
                        <TextBox x:Name="TxtDocPath"/>
                    </DockPanel>
                    <Button Content="🏗️ Crear Estructura de Carpetas" Click="BtnCreateFolders_Click" Margin="0,10" HorizontalAlignment="Left"/>

                    <TextBlock Text="Carpeta de Backups" Style="{StaticResource SectionHeader}"/>
                    <Label Content="Carpeta destino de backups:"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="📂" Click="BtnBrowseBackupPath_Click" Width="40" Margin="4,0,0,0"/>
                        <TextBox x:Name="TxtBackupPath"/>
                    </DockPanel>
                    <Button Content="🧪 Probar Permisos de Escritura" Click="BtnTestPermissions_Click" Margin="0,10" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="TxtFolderStatus" Foreground="#FFA6E3A1" Margin="0,10" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>

            <!-- ═══ Backup Tab ═══ -->
            <TabItem Header="💾 Backup" Foreground="#FFCDD6F4">
                <StackPanel Margin="16">
                    <TextBlock Text="Configuración de Backup Automático" Style="{StaticResource SectionHeader}"/>
                    <CheckBox x:Name="ChkBackupEnabled" Content="Habilitar backup automático" IsChecked="True" Margin="0,6"/>

                    <Label Content="Primer horario diario (HH:mm):"/>
                    <TextBox x:Name="TxtBackupTime1" Text="02:00" Width="100" HorizontalAlignment="Left"/>

                    <CheckBox x:Name="ChkBackupTime2" Content="Habilitar segundo backup diario" Margin="0,12,0,0"/>
                    <Label Content="Segundo horario (HH:mm):"/>
                    <TextBox x:Name="TxtBackupTime2" Text="14:00" Width="100" HorizontalAlignment="Left"/>

                    <Label Content="Retención (días):"/>
                    <TextBox x:Name="TxtRetentionDays" Text="30" Width="80" HorizontalAlignment="Left"/>

                    <CheckBox x:Name="ChkFullDocBackup" Content="Backup documental completo (no incremental)" IsChecked="True" Margin="0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                        <Button x:Name="BtnBackupNow" Content="▶️ Ejecutar Backup Ahora" Click="BtnBackupNow_Click" Margin="0,0,10,0"/>
                        <Button x:Name="BtnViewLogs" Content="📋 Ver Logs" Click="BtnViewLogs_Click"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtBackupStatus" Foreground="#FFA6E3A1" Margin="0,10" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Save Button -->
        <Button x:Name="BtnSave" Content="💾  Guardar Configuración" Click="BtnSave_Click"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Background="#FF89B4FA" Foreground="#FF1E1E2E" FontWeight="Bold"
                Padding="20,10" FontSize="14"/>
    </Grid>
</Window>
