@page "/login"
@using Microsoft.AspNetCore.Components.Authorization
@attribute [AllowAnonymous]
@inject NavigationManager nav

<PageTitle>Iniciar Sesión - QMSFlowDoc</PageTitle>

<div class="login-wrapper">
    <div class="login-card p-5">
        <div class="brand-section text-center mb-4">
            <div class="logo-outer mx-auto mb-3">
                <div class="logo-inner">
                    <i class="bi bi-diagram-3-fill text-white"></i>
                </div>
            </div>
            <h2 class="fw-bold text-dark mb-1">QMSFlowDoc</h2>
            <p class="text-muted small">Gestión de Calidad e Inventario &bull; ISO 15189</p>
        </div>

        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="alert alert-danger d-flex align-items-center" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <div>@ErrorMessage</div>
            </div>
        }

        <form action="/account/login" method="post">
            <AntiforgeryToken />
            
            <div class="mb-3">
                <label for="username" class="form-label fw-medium text-secondary">Usuario</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-person text-muted"></i></span>
                    <input type="text" name="Username" id="username" class="form-control form-control-premium border-start-0 ps-1" placeholder="Ej. admin" required autocomplete="username" />
                </div>
            </div>
            
            <div class="mb-4">
                <label for="password" class="form-label fw-medium text-secondary">Contraseña</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="bi bi-lock text-muted"></i></span>
                    <input type="password" name="Password" id="password" class="form-control form-control-premium border-start-0 ps-1" placeholder="••••••••" required autocomplete="current-password" />
                </div>
            </div>
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="form-check">
                    <input class="form-check-input darker-border-checkbox" type="checkbox" name="RememberMe" id="rememberMe" />
                    <label class="form-check-label text-secondary small" for="rememberMe">
                        Recordar sesión
                    </label>
                </div>
            </div>

            <button type="submit" class="btn btn-premium w-100 py-2.5">
                <i class="bi bi-box-arrow-in-right me-2"></i>Acceder al Portal
            </button>
        </form>

        <div class="mt-5 text-center small text-muted">
            &copy; 2026 QMSFlowDoc Intranet &bull; Control Calidad
        </div>
    </div>
</div>

<style>
    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at 10% 20%, rgba(248, 250, 252, 1) 0%, rgba(226, 232, 240, 1) 100%);
        padding: 1.5rem;
    }
    
    .login-card {
        width: 100%;
        max-width: 440px;
        background-color: #ffffff;
        border-radius: 24px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        border: 1px solid rgba(226, 232, 240, 0.8);
    }

    .logo-outer {
        width: 60px;
        height: 60px;
        padding: 5px;
        background-color: rgba(79, 70, 229, 0.08);
        border-radius: 50%;
    }

    .logo-inner {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .logo-inner i {
        font-size: 1.6rem;
    }
</style>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private string? ErrorMessage => Error switch {
        "Invalid login attempt" => "Usuario o contraseña incorrectos.",
        "Please provide username and password" => "Por favor, complete todos los campos.",
        _ => Error
    };

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var user = (await AuthStateTask).User;
            if (user.Identity?.IsAuthenticated == true)
            {
                nav.NavigateTo("/");
            }
        }
    }
}
