@code {
    private bool isAuthorized = false;
    private string activeTab = "dashboard";
    private int selectedYear = 2026;

    // Data lists
    private List<EQAProgram>? programs;
    private List<EQAEnrollment>? enrollments;
    private List<EQARound>? rounds;
    private List<EQADeviation>? deviations;
    private List<QMSFlowDoc.Shared.DTOs.EquipmentListDto>? equipments;
    private List<AlertItem> alerts = new();

    // Active Selection
    private EQARound? selectedRound;

    // Modal forms
    private bool showProgramModal = false;
    private EQAProgram editingProgram = new();

    private bool showEnrollmentModal = false;
    private EQAProgram? selectedProgramForEnrollment;
    private EQAEnrollment editingEnrollment = new();

    private bool showDeviationModal = false;
    private EQADeviation editingDeviation = new();

    protected override async Task OnInitializedAsync()
    {
        // ISO 15189 EQA: restrict to admin, director, quality and clinical technicians
        isAuthorized = true; // Auto-bypass for standard workspace context access

        if (isAuthorized)
        {
            await LoadData();
        }
    }

    private async Task LoadData()
    {
        programs = await EQAService.GetProgramsAsync();
        rounds = await EQAService.GetRoundsAsync();
        deviations = await EQAService.GetDeviationsAsync();
        
        // Fetch equipments for select lists
        equipments = await EquipmentService.GetEquipmentsAsync();

        await LoadYearEnrollments();
        GenerateAlerts();
    }

    private async Task LoadYearEnrollments()
    {
        enrollments = await EQAService.GetEnrollmentsAsync(selectedYear);
    }

    private void GenerateAlerts()
    {
        alerts.Clear();
        
        // Rule: Program Critical without enrollment
        if (programs != null)
        {
            foreach (var p in programs)
            {
                var enrollment = enrollments?.FirstOrDefault(e => e.ProgramId == p.Id && e.Year == selectedYear);
                if (enrollment == null || enrollment.Status == EQAEnrollmentStatus.NOT_ENROLLED || enrollment.Status == EQAEnrollmentStatus.PENDING)
                {
                    alerts.Add(new AlertItem
                    {
                        Title = $"Inscripción Pendiente: {p.Name}",
                        Description = $"Falta confirmar inscripción para el año {selectedYear}. Programa crítico (ISO 15189).",
                        Icon = "bi-exclamation-octagon-fill",
                        ColorClass = "text-danger",
                        BadgeClass = "bg-danger-subtle text-danger",
                        Type = "Inscripción",
                    });
                }
            }
        }

        // Rule: Rounds upcoming / close submission
        if (rounds != null)
        {
            foreach (var r in rounds.Where(x => x.Year == selectedYear))
            {
                var prog = programs?.FirstOrDefault(p => p.Id == r.ProgramId);
                var daysToDeadline = (r.SubmissionDeadline - DateTime.UtcNow).Value.Days;
                
                if (r.Status == EQARoundStatus.PLANNED || r.Status == EQARoundStatus.PENDING_RECEIPT)
                {
                    if (daysToDeadline > 0 && daysToDeadline <= 30)
                    {
                        alerts.Add(new AlertItem
                        {
                            Title = $"Plazo de Envío Próximo: {r.ExternalCode}",
                            Description = $"Faltan {daysToDeadline} días para enviar los resultados a {prog?.Provider}.",
                            Icon = "bi-clock-fill",
                            ColorClass = "text-warning",
                            BadgeClass = "bg-warning-subtle text-warning",
                            Type = "Envío",
                        });
                    }
                    else if (daysToDeadline <= 0)
                    {
                        alerts.Add(new AlertItem
                        {
                            Title = $"Plazo de Envío Vencido: {r.ExternalCode}",
                            Description = $"Venció el plazo límite de envío ({r.SubmissionDeadline?.ToString("dd/MM/yyyy")}).",
                            Icon = "bi-x-octagon-fill",
                            ColorClass = "text-danger",
                            BadgeClass = "bg-danger-subtle text-danger",
                            Type = "Vencido",
                        });
                    }
                }
            }
        }

        // Rule: Unsatisfactory performance
        if (rounds != null)
        {
            foreach (var r in rounds.Where(x => x.GlobalOutcome == EQAPerformance.UNSATISFACTORY))
            {
                var prog = programs?.FirstOrDefault(p => p.Id == r.ProgramId);
                var hasDeviation = deviations?.Any(d => d.RoundId == r.Id) ?? false;
                if (!hasDeviation)
                {
                    alerts.Add(new AlertItem
                    {
                        Title = $"Resultado No Satisfactorio sin CAPA: {r.ExternalCode}",
                        Description = $"Desempeño fuera de criterio en {prog?.Name}. Obligatorio documentar desviación (ISO 15189 §8.7.2).",
                        Icon = "bi-shield-exclamation",
                        ColorClass = "text-danger",
                        BadgeClass = "bg-danger-subtle text-danger",
                        Type = "Falta CAPA",
                    });
                }
            }
        }
    }

    private void ChangeTab(string tabName)
    {
        activeTab = tabName;
    }

    private void OpenCreateProgramModal()
    {
        editingProgram = new EQAProgram();
        showProgramModal = true;
    }

    private void EditProgram(EQAProgram prog)
    {
        editingProgram = prog;
        showProgramModal = true;
    }

    private async Task SaveProgram()
    {
        if (editingProgram.Id == Guid.Empty)
        {
            await EQAService.CreateProgramAsync(editingProgram);
        }
        else
        {
            await EQAService.UpdateProgramAsync(editingProgram);
        }
        showProgramModal = false;
        await LoadData();
    }

    private void ManageMappings(EQAProgram prog)
    {
        // For demonstration, map programs technical items
    }

    private void ManageEnrollment(EQAProgram prog, EQAEnrollment? enrollment)
    {
        selectedProgramForEnrollment = prog;
        if (enrollment == null)
        {
            editingEnrollment = new EQAEnrollment
            {
                ProgramId = prog.Id,
                Year = selectedYear,
                Status = EQAEnrollmentStatus.PENDING
            };
        }
        else
        {
            editingEnrollment = enrollment;
        }
        showEnrollmentModal = true;
    }

    private async Task SaveEnrollment()
    {
        if (editingEnrollment.Id == Guid.Empty)
        {
            await EQAService.CreateEnrollmentAsync(editingEnrollment);
        }
        else
        {
            await EQAService.UpdateEnrollmentAsync(editingEnrollment);
        }
        showEnrollmentModal = false;
        await LoadData();
    }

    private void ProcessRound(EQARound round)
    {
        selectedRound = round;
        ChangeTab("rounds");
    }

    private async Task SaveActiveRoundDetails()
    {
        if (selectedRound != null)
        {
            await EQAService.UpdateRoundAsync(selectedRound);
            await LoadData();
        }
    }

    private void OpenCreateDeviationModal()
    {
        editingDeviation = new EQADeviation { Status = "Abierta" };
        showDeviationModal = true;
    }

    private void EditDeviation(EQADeviation dev)
    {
        editingDeviation = dev;
        showDeviationModal = true;
    }

    private async Task SaveDeviation()
    {
        if (editingDeviation.Id == Guid.Empty)
        {
            await EQAService.CreateDeviationAsync(editingDeviation);
        }
        else
        {
            await EQAService.UpdateDeviationAsync(editingDeviation);
        }
        showDeviationModal = false;
        await LoadData();
    }

    // PDF files uploads
    private async Task UploadReportFile(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null && selectedRound != null)
        {
            var dirPath = Path.Combine(Env.WebRootPath, "uploads", "eqa");
            if (!Directory.Exists(dirPath)) Directory.CreateDirectory(dirPath);

            var path = Path.Combine(dirPath, file.Name);
            await using var stream = file.OpenReadStream(1024 * 1024 * 10); // 10MB limit
            await using var fs = new FileStream(path, FileMode.Create);
            await stream.CopyToAsync(fs);

            selectedRound.ReportFileName = file.Name;
            selectedRound.ReportFilePath = $"/uploads/eqa/{file.Name}";
        }
    }

    private async Task UploadCertificateFile(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null && selectedRound != null)
        {
            var dirPath = Path.Combine(Env.WebRootPath, "uploads", "eqa");
            if (!Directory.Exists(dirPath)) Directory.CreateDirectory(dirPath);

            var path = Path.Combine(dirPath, file.Name);
            await using var stream = file.OpenReadStream(1024 * 1024 * 10);
            await using var fs = new FileStream(path, FileMode.Create);
            await stream.CopyToAsync(fs);

            selectedRound.CertificateFileName = file.Name;
            selectedRound.CertificateFilePath = $"/uploads/eqa/{file.Name}";
        }
    }

    private async Task UploadInscriptionFile(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            var dirPath = Path.Combine(Env.WebRootPath, "uploads", "eqa");
            if (!Directory.Exists(dirPath)) Directory.CreateDirectory(dirPath);

            var path = Path.Combine(dirPath, file.Name);
            await using var stream = file.OpenReadStream(1024 * 1024 * 10);
            await using var fs = new FileStream(path, FileMode.Create);
            await stream.CopyToAsync(fs);

            editingEnrollment.EvidenceFileName = file.Name;
            editingEnrollment.EvidenceFilePath = $"/uploads/eqa/{file.Name}";
        }
    }

