@page "/eqa"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using QMSFlowDoc.Domain.Entities
@using QMSFlowDoc.Application.Services.EQA
@using QMSFlowDoc.Application.Services.Identity
@using QMSFlowDoc.Application.Services.Equipment
@using System.Security.Claims
@using System.Text.Json
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject IEQAService EQAService
@inject IPermissionService PermissionService
@inject IEquipmentService EquipmentService
@inject IJSRuntime JS
@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment Env

<PageTitle>Evaluación Externa de la Calidad (EQA) — QMSFlowDoc</PageTitle>

<div class="container-fluid py-4 px-4">
    @if (!isAuthorized)
    {
        <div class="alert alert-danger rounded-4 shadow-sm p-4 d-flex align-items-center" role="alert">
            <i class="bi bi-shield-lock-fill fs-1 me-4"></i>
            <div>
                <h4 class="alert-heading fw-bold mb-1">Acceso Denegado</h4>
                <p class="mb-0">No tiene los permisos de lectura suficientes para acceder a la gestión de EQA (ISO 15189 §7.3.7.3).</p>
            </div>
        </div>
    }
    else
    {
        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
            <div>
                <h2 class="fw-bold text-dark mb-1">
                    <i class="bi bi-globe text-primary me-2"></i>Evaluación Externa de la Calidad (EQA)
                </h2>
                <p class="text-muted mb-0">Control interlaboratorios y aseguramiento de la validez de los resultados clínicos (ISO 15189:2022 §7.3.7.3).</p>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary rounded-pill px-3" @onclick="() => LoadData()">
                    <i class="bi bi-arrow-clockwise me-1"></i>Actualizar
                </button>
                <button class="btn btn-primary rounded-pill px-4" @onclick="OpenCreateProgramModal">
                    <i class="bi bi-plus-circle me-2"></i>Nuevo Programa
                </button>
            </div>
        </div>

        <!-- Navigation Tabs -->
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-header bg-white border-0 pt-3 pb-0 px-4">
                <ul class="nav nav-tabs nav-tabs-premium border-0" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "dashboard" ? "active" : "")" @onclick='() => ChangeTab("dashboard")'>
                            <i class="bi bi-grid-1x2-fill me-2"></i>Dashboard y Alertas
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "programs" ? "active" : "")" @onclick='() => ChangeTab("programs")'>
                            <i class="bi bi-card-list me-2"></i>Catálogo de Programas
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "enrollments" ? "active" : "")" @onclick='() => ChangeTab("enrollments")'>
                            <i class="bi bi-journal-check me-2"></i>Inscripciones y Calendario
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "rounds" ? "active" : "")" @onclick='() => ChangeTab("rounds")'>
                            <i class="bi bi-calendar-event me-2"></i>Gestión de Rondas
                        </button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link @(activeTab == "deviations" ? "active" : "")" @onclick='() => ChangeTab("deviations")'>
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>Desviaciones y CAPA
                        </button>
                    </li>
                </ul>
            </div>
        </div>

        <!-- TAB CONTENT -->
        <div class="tab-content">
            @if (activeTab == "dashboard")
            {
                <!-- DASHBOARD -->
                <div class="row g-3 mb-4">
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm rounded-4 bg-primary text-white p-4 h-100 position-relative overflow-hidden">
                            <h6 class="text-white-50 fw-semibold mb-1">Inscripciones Activas</h6>
                            <h2 class="fw-bold mb-0">@programs?.Count(p => p.Status == EQAStatus.ACTIVE) / @programs?.Count</h2>
                            <p class="small text-white-50 mt-2 mb-0">Programas de citometría en curso</p>
                            <i class="bi bi-award-fill position-absolute end-0 bottom-0 opacity-10 fs-1 me-3 mb-2" style="font-size: 5rem !important;"></i>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm rounded-4 bg-success text-white p-4 h-100 position-relative overflow-hidden">
                            <h6 class="text-white-50 fw-semibold mb-1">Satisfactorios (2026)</h6>
                            <h2 class="fw-bold mb-0">
                                @(rounds?.Count(r => r.Year == 2026 && r.GlobalOutcome == EQAPerformance.SATISFACTORY) ?? 0)
                            </h2>
                            <p class="small text-white-50 mt-2 mb-0">Rondas con desempeño óptimo</p>
                            <i class="bi bi-shield-check position-absolute end-0 bottom-0 opacity-10 fs-1 me-3 mb-2" style="font-size: 5rem !important;"></i>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm rounded-4 bg-warning text-dark p-4 h-100 position-relative overflow-hidden">
                            <h6 class="text-dark-50 fw-semibold mb-1">Acciones Pendientes</h6>
                            <h2 class="fw-bold mb-0">@deviations?.Count(d => d.Status == "Abierta")</h2>
                            <p class="small text-dark-50 mt-2 mb-0">Desviaciones con CAPA abiertas</p>
                            <i class="bi bi-clock-history position-absolute end-0 bottom-0 opacity-10 fs-1 me-3 mb-2" style="font-size: 5rem !important;"></i>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="card border-0 shadow-sm rounded-4 bg-danger text-white p-4 h-100 position-relative overflow-hidden">
                            <h6 class="text-white-50 fw-semibold mb-1">No Satisfactorios</h6>
                            <h2 class="fw-bold mb-0">
                                @(rounds?.Count(r => r.GlobalOutcome == EQAPerformance.UNSATISFACTORY) ?? 0)
                            </h2>
                            <p class="small text-white-50 mt-2 mb-0">Rondas fuera de criterio</p>
                            <i class="bi bi-x-circle-fill position-absolute end-0 bottom-0 opacity-10 fs-1 me-3 mb-2" style="font-size: 5rem !important;"></i>
                        </div>
                    </div>
                </div>

                <!-- Alert cards / ISO checklist -->
                <div class="row g-4">
                    <div class="col-md-8">
                        <div class="card border-0 shadow-sm rounded-4 h-100">
                            <div class="card-body p-4">
                                <h5 class="fw-bold text-dark mb-3"><i class="bi bi-bell-fill text-warning me-2"></i>Alertas de Calidad y Plazos</h5>
                                <div class="list-group list-group-flush">
                                    @if (alerts.Any())
                                    {
                                        @foreach (var alert in alerts)
                                        {
                                            <div class="list-group-item d-flex justify-content-between align-items-center py-3 border-0 border-bottom border-light">
                                                <div class="d-flex align-items-start">
                                                    <i class="bi @alert.Icon fs-5 me-3 @alert.ColorClass"></i>
                                                    <div>
                                                        <h6 class="fw-semibold mb-1">@alert.Title</h6>
                                                        <p class="text-muted small mb-0">@alert.Description</p>
                                                    </div>
                                                </div>
                                                <span class="badge rounded-pill px-2.5 py-1.5 @alert.BadgeClass">@alert.Type</span>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="text-center py-5 text-muted">
                                            <i class="bi bi-check-circle-fill text-success fs-1 mb-2 d-block"></i>
                                            <h6 class="fw-semibold">Sin alertas de plazos o desviaciones</h6>
                                            <p class="small mb-0">Todas las rondas e inscripciones cumplen la planificación ISO 15189.</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm rounded-4 h-100 bg-light-subtle">
                            <div class="card-body p-4">
                                <h5 class="fw-bold text-dark mb-3"><i class="bi bi-bookmark-star-fill text-primary me-2"></i>ISO 15189 Checklist</h5>
                                <div class="d-flex flex-column gap-3">
                                    <div class="p-3 bg-white rounded-3 border">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="small fw-bold">Pruebas Críticas Cubiertas</span>
                                            <span class="badge bg-success">100%</span>
                                        </div>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-success" style="width: 100%;"></div>
                                        </div>
                                    </div>
                                    <div class="p-3 bg-white rounded-3 border">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="small fw-bold">Rondas en Plazo</span>
                                            <span class="badge bg-primary">95.4%</span>
                                        </div>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-primary" style="width: 95.4%;"></div>
                                        </div>
                                    </div>
                                    <div class="p-3 bg-white rounded-3 border">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <span class="small fw-bold">Eficacia CAPAs EQA</span>
                                            <span class="badge bg-info">100%</span>
                                        </div>
                                        <div class="progress" style="height: 6px;">
                                            <div class="progress-bar bg-info" style="width: 100%;"></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (activeTab == "programs")
            {
                <!-- PROGRAMS CATALOG -->
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="bg-light small fw-bold text-secondary">
                                <tr>
                                    <th>Código</th>
                                    <th>Programa</th>
                                    <th>Proveedor</th>
                                    <th>Subárea</th>
                                    <th>Tipo Muestra</th>
                                    <th>Periodicidad</th>
                                    <th>Estado</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody class="small">
                                @if (programs == null)
                                {
                                    <tr>
                                        <td colspan="8" class="text-center py-4">Cargando catálogo...</td>
                                    </tr>
                                }
                                else if (!programs.Any())
                                {
                                    <tr>
                                        <td colspan="8" class="text-center py-4 text-muted">No hay programas de control externo registrados.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var prog in programs)
                                    {
                                        <tr>
                                            <td class="fw-bold">@prog.InternalCode</td>
                                            <td>
                                                <div class="fw-bold text-dark">@prog.Name</div>
                                                <div class="text-muted small">@prog.CoordinatorEntity</div>
                                            </td>
                                            <td>@prog.Provider</td>
                                            <td>
                                                <span class="badge bg-secondary-subtle text-secondary rounded-pill">
                                                    @GetSubAreaName(prog.SubArea)
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge bg-info-subtle text-info rounded-pill">
                                                    @prog.SampleType
                                                </span>
                                            </td>
                                            <td>@prog.Periodicity</td>
                                            <td>
                                                <span class="badge rounded-pill @(prog.Status == EQAStatus.ACTIVE ? "bg-success" : "bg-danger")">
                                                    @prog.Status
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-outline-primary btn-sm rounded-pill me-1" @onclick="() => EditProgram(prog)">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <button class="btn btn-outline-info btn-sm rounded-pill" @onclick="() => ManageMappings(prog)">
                                                    <i class="bi bi-link-45deg"></i> Pruebas
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else if (activeTab == "enrollments")
            {
                <!-- ENROLLMENTS AND CALENDAR -->
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm rounded-4 p-4">
                            <h5 class="fw-bold mb-3"><i class="bi bi-journal-check text-primary me-2"></i>Inscripciones Anuales</h5>
                            <div class="mb-3">
                                <label class="form-label small fw-semibold text-secondary">Año Seleccionado</label>
                                <select class="form-select form-select-premium" @bind="selectedYear" @bind:after="LoadYearEnrollments">
                                    <option value="2026">2026</option>
                                    <option value="2025">2025</option>
                                </select>
                            </div>
                            <div class="list-group">
                                @if (programs != null)
                                {
                                    @foreach (var prog in programs)
                                    {
                                        var enrollment = enrollments?.FirstOrDefault(e => e.ProgramId == prog.Id && e.Year == selectedYear);
                                        <div class="list-group-item list-group-item-action border border-light rounded-3 p-3 mb-2">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <h6 class="fw-bold mb-1 text-dark">@prog.Name</h6>
                                                    <p class="small text-muted mb-1">Part. Code: @(enrollment?.ParticipantCode ?? "No Inscrito")</p>
                                                    @if (enrollment?.IsCritical == true)
                                                    {
                                                        <span class="badge bg-danger rounded-pill">Crítico (Alcance Acreditado)</span>
                                                    }
                                                </div>
                                                <span class="badge @GetEnrollmentBadgeClass(enrollment?.Status)">
                                                    @(enrollment?.Status.ToString() ?? "NOT_ENROLLED")
                                                </span>
                                            </div>
                                            <div class="d-flex justify-content-end gap-1 mt-2">
                                                <button class="btn btn-sm btn-outline-primary rounded-pill px-3" @onclick="() => ManageEnrollment(prog, enrollment)">
                                                    Configurar
                                                </button>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <div class="col-md-8">
                        <div class="card border-0 shadow-sm rounded-4 p-4">
                            <h5 class="fw-bold mb-3"><i class="bi bi-calendar-event text-primary me-2"></i>Calendario y Plazos de Envío</h5>
                            <div class="table-responsive">
                                <table class="table align-middle">
                                    <thead class="bg-light small fw-bold text-secondary">
                                        <tr>
                                            <th>Ronda</th>
                                            <th>Recepción Prevista</th>
                                            <th>Recepción Real</th>
                                            <th>Límite Envío</th>
                                            <th>Envío Real</th>
                                            <th>Estado</th>
                                            <th class="text-end">Acción</th>
                                        </tr>
                                    </thead>
                                    <tbody class="small">
                                        @if (rounds == null)
                                        {
                                            <tr>
                                                <td colspan="7" class="text-center py-4">Cargando calendario...</td>
                                            </tr>
                                        }
                                        else if (!rounds.Any(r => r.Year == selectedYear))
                                        {
                                            <tr>
                                                <td colspan="7" class="text-center py-4 text-muted">No hay rondas planificadas para el año @selectedYear.</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var round in rounds.Where(r => r.Year == selectedYear).OrderBy(r => r.ExpectedReceiptDate))
                                            {
                                                var prog = programs?.FirstOrDefault(p => p.Id == round.ProgramId);
                                                <tr>
                                                    <td>
                                                        <div class="fw-bold text-dark">@round.ExternalCode</div>
                                                        <div class="text-muted small">@prog?.Name</div>
                                                    </td>
                                                    <td>@round.ExpectedReceiptDate?.ToString("dd/MM/yyyy")</td>
                                                    <td>@(round.RealReceiptDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                                    <td class="fw-semibold text-danger">@round.SubmissionDeadline?.ToString("dd/MM/yyyy")</td>
                                                    <td>@(round.RealSubmissionDate?.ToString("dd/MM/yyyy") ?? "-")</td>
                                                    <td>
                                                        <span class="badge rounded-pill @GetRoundBadgeClass(round.Status)">
                                                            @round.Status
                                                        </span>
                                                    </td>
                                                    <td class="text-end">
                                                        <button class="btn btn-sm btn-primary rounded-pill px-3" @onclick="() => ProcessRound(round)">
                                                            Gestionar
                                                        </button>
                                                    </td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (activeTab == "rounds")
            {
                <!-- ROUND PROCESSOR -->
                @if (selectedRound == null)
                {
                    <div class="card border-0 shadow-sm rounded-4 p-5 text-center text-muted">
                        <i class="bi bi-calendar-check fs-1 mb-3 text-secondary opacity-50"></i>
                        <h5>Seleccione una ronda en el Calendario o en las Inscripciones para iniciar su gestión</h5>
                        <p class="small">El procesamiento de la ronda cumple con la exigencia de trazabilidad del flujo de trabajo habitual (ISO 15189 §7.3).</p>
                        <button class="btn btn-primary rounded-pill px-4 mt-3" @onclick='() => ChangeTab("enrollments")'>
                            Ir a Calendario
                        </button>
                    </div>
                }
                else
                {
                    var prog = programs?.FirstOrDefault(p => p.Id == selectedRound.ProgramId);
                    <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
                        <div class="d-flex justify-content-between align-items-start border-bottom pb-3 mb-4">
                            <div>
                                <span class="badge bg-secondary rounded-pill mb-2">@prog?.Name</span>
                                <h4 class="fw-bold text-dark mb-1">Ronda: @selectedRound.ExternalCode</h4>
                                <p class="text-muted small mb-0">Estado de la Ronda: <strong>@selectedRound.Status</strong> | Tipo: <strong>@selectedRound.RoundType</strong></p>
                            </div>
                            <div class="d-flex gap-2">
                                <button class="btn btn-outline-secondary rounded-pill px-3" @onclick="() => selectedRound = null">
                                    <i class="bi bi-arrow-left me-1"></i>Atrás
                                </button>
                                <button class="btn btn-success rounded-pill px-4" @onclick="SaveActiveRoundDetails">
                                    <i class="bi bi-save me-2"></i>Guardar Cambios
                                </button>
                            </div>
                        </div>

                        <div class="row g-4">
                            <!-- Left: Schedule & Files -->
                            <div class="col-md-6">
                                <h5 class="fw-bold mb-3"><i class="bi bi-clock-history text-primary me-2"></i>Hitos y Fechas</h5>
                                <div class="row g-3 mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-semibold text-secondary">Fecha Recepción Real</label>
                                        <input type="date" class="form-control form-control-premium" @bind="selectedRound.RealReceiptDate" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-semibold text-secondary">Fecha Límite de Envío</label>
                                        <input type="date" class="form-control form-control-premium" @bind="selectedRound.SubmissionDeadline" disabled />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-semibold text-secondary">Fecha Envío Real</label>
                                        <input type="date" class="form-control form-control-premium" @bind="selectedRound.RealSubmissionDate" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-semibold text-secondary">Estado Ronda</label>
                                        <select class="form-select form-select-premium" @bind="selectedRound.Status">
                                            @foreach (var val in Enum.GetValues<EQARoundStatus>())
                                            {
                                                <option value="@val">@val</option>
                                            }
                                        </select>
                                    </div>
                                </div>

                                <!-- PDF report results upload -->
                                <h5 class="fw-bold mb-3"><i class="bi bi-file-earmark-pdf-fill text-danger me-2"></i>Informe y Certificado EQA</h5>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-semibold text-secondary">PDF Informe Recibido</label>
                                        <InputFile class="form-control" OnChange="UploadReportFile" />
                                        @if (!string.IsNullOrEmpty(selectedRound.ReportFileName))
                                        {
                                            <div class="small text-success mt-1"><i class="bi bi-check-circle me-1"></i>@selectedRound.ReportFileName</div>
                                        }
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-semibold text-secondary">PDF Certificado</label>
                                        <InputFile class="form-control" OnChange="UploadCertificateFile" />
                                        @if (!string.IsNullOrEmpty(selectedRound.CertificateFileName))
                                        {
                                            <div class="small text-success mt-1"><i class="bi bi-check-circle me-1"></i>@selectedRound.CertificateFileName</div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- Right: Muestras -->
                            <div class="col-md-6 border-start ps-4">
                                <h5 class="fw-bold mb-3"><i class="bi bi-bezier2 text-primary me-2"></i>Procesamiento de Muestras / FCS</h5>
                                <div class="list-group">
                                    @foreach (var sample in selectedRound.Samples)
                                    {
                                        <div class="list-group-item p-3 mb-3 border rounded-3 bg-light-subtle">
                                            <div class="d-flex justify-content-between align-items-center mb-2">
                                                <h6 class="fw-bold mb-0 text-dark">@sample.InternalCode</h6>
                                                <span class="badge bg-secondary">@sample.SampleType</span>
                                            </div>
                                            
                                            <div class="row g-2 mb-3">
                                                <div class="col-md-6">
                                                    <label class="form-label small text-secondary mb-0.5">Integridad Muestra</label>
                                                    <select class="form-select form-select-sm" @bind="sample.Integrity">
                                                        @foreach (var val in Enum.GetValues<EQAIntegrity>())
                                                        {
                                                            <option value="@val">@val</option>
                                                        }
                                                    </select>
                                                </div>
                                                <div class="col-md-6">
                                                    <label class="form-label small text-secondary mb-0.5">Fecha Análisis</label>
                                                    <input type="date" class="form-control form-control-sm" @bind="sample.ProcessingEnd" />
                                                </div>
                                                <div class="col-md-12">
                                                    <label class="form-label small text-secondary mb-0.5">Equipo de Adquisición</label>
                                                    <select class="form-select form-select-sm" @bind="sample.EquipmentId">
                                                        <option value="">Seleccione equipo...</option>
                                                        @if (equipments != null)
                                                        {
                                                            @foreach (var eq in equipments)
                                                            {
                                                                <option value="@eq.Id">@eq.Name (@eq.InternalId)</option>
                                                            }
                                                        }
                                                    </select>
                                                </div>
                                            </div>

                                            <div class="mb-2">
                                                <label class="form-label small text-secondary mb-0.5">Valores de Resultados Enviados (Parámetros)</label>
                                                <textarea class="form-control form-control-sm" rows="3" placeholder="CD3+ % = 74.2&#10;CD34+ abs/uL = 42.1&#10;Resultado = Positivo" @bind="sample.SubmittedResultsJson"></textarea>
                                            </div>

                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" @bind="sample.FollowedRoutineProcedure" id="@($"chk-{sample.Id}")" />
                                                <label class="form-check-label small" for="@($"chk-{sample.Id}")">
                                                    ¿Tratada como muestra de paciente rutinaria? (ISO 15189)
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <!-- Provider report analysis & Internal evaluation -->
                        <div class="border-top mt-4 pt-4">
                            <h5 class="fw-bold mb-3 text-dark"><i class="bi bi-clipboard-data text-primary me-2"></i>Recepción de Informe y Evaluación de Desempeño</h5>
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label small fw-semibold text-secondary">Resultado Global Proveedor</label>
                                    <select class="form-select form-select-premium" @bind="selectedRound.GlobalOutcome">
                                        @foreach (var val in Enum.GetValues<EQAPerformance>())
                                        {
                                            <option value="@val">@val</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-semibold text-secondary">Puntuación Global (Score)</label>
                                    <input type="number" step="0.01" class="form-control form-control-premium" @bind="selectedRound.GlobalScore" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-semibold text-secondary">Fecha Evaluación Interna</label>
                                    <input type="date" class="form-control form-control-premium" @bind="selectedRound.InternalEvaluationDate" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label small fw-semibold text-secondary">¿Requiere Acción Correctiva?</label>
                                    <select class="form-select form-select-premium" @bind="selectedRound.RequiresAction">
                                        <option value="false">No</option>
                                        <option value="true">Sí (Abrir Desviación)</option>
                                    </select>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold text-secondary">Comentarios del Evaluador Externo</label>
                                    <textarea class="form-control form-control-premium" rows="2" @bind="selectedRound.AssessorComments"></textarea>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small fw-semibold text-secondary">Justificación / Observaciones Internas</label>
                                    <textarea class="form-control form-control-premium" rows="2" @bind="selectedRound.InternalNotes"></textarea>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else if (activeTab == "deviations")
            {
                <!-- DEVIATIONS & CAPA -->
                <div class="card border-0 shadow-sm rounded-4 p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-shield-slash-fill text-danger me-2"></i>Desviaciones y Acciones Correctivas (CAPA)</h5>
                        <button class="btn btn-danger btn-sm rounded-pill px-3" @onclick="OpenCreateDeviationModal">
                            <i class="bi bi-plus-circle me-1"></i>Registrar Desviación
                        </button>
                    </div>

                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="bg-light small fw-bold text-secondary">
                                <tr>
                                    <th>Ronda / Programa</th>
                                    <th>Tipo Desviación</th>
                                    <th>Causa Probable</th>
                                    <th>Gravedad</th>
                                    <th>Estado</th>
                                    <th>Eficacia</th>
                                    <th class="text-end">Acciones</th>
                                </tr>
                            </thead>
                            <tbody class="small">
                                @if (deviations == null || !deviations.Any())
                                {
                                    <tr>
                                        <td colspan="7" class="text-center py-4 text-muted">No hay desviaciones registradas.</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var dev in deviations)
                                    {
                                        var r = rounds?.FirstOrDefault(x => x.Id == dev.RoundId);
                                        var p = programs?.FirstOrDefault(x => x.Id == r?.ProgramId);
                                        <tr>
                                            <td>
                                                <div class="fw-bold text-dark">@(r?.ExternalCode ?? "N/A")</div>
                                                <div class="text-muted small">@(p?.Name ?? "N/A")</div>
                                            </td>
                                            <td>@dev.DeviationType</td>
                                            <td>@dev.ProbableCause</td>
                                            <td>
                                                <span class="badge @(dev.Severity == EQADeviationSeverity.CRITICAL ? "bg-danger" : "bg-warning")">
                                                    @dev.Severity
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge @(dev.Status == "Cerrada" ? "bg-success" : "bg-primary")">
                                                    @dev.Status
                                                </span>
                                            </td>
                                            <td>
                                                <span class="badge @(dev.EffectivenessOutcome == "Eficaz" ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">
                                                    @(dev.EffectivenessOutcome ?? "Pendiente")
                                                </span>
                                            </td>
                                            <td class="text-end">
                                                <button class="btn btn-sm btn-outline-primary rounded-pill" @onclick="() => EditDeviation(dev)">
                                                    Gestionar CAPA / Eficacia
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- MODALS -->

