        EQASubArea.CD34 => "CD34 / Stem Cells",
        EQASubArea.LEUKEMIA_LYMPHOMA => "Leucemias/Linfomas",
        EQASubArea.LCR => "Subpoblaciones LCR",
        EQASubArea.HPN => "HPN",
        EQASubArea.EMR_MM => "EMR Mieloma Múltiple",
        EQASubArea.EMR_LLA => "EMR LLA",
        _ => "Otro"
    };

    private string GetEnrollmentBadgeClass(EQAEnrollmentStatus? val) => val switch
    {
        EQAEnrollmentStatus.CONFIRMED => "bg-success",
        EQAEnrollmentStatus.REQUESTED => "bg-warning text-dark",
        EQAEnrollmentStatus.PENDING => "bg-secondary-subtle text-secondary",
        EQAEnrollmentStatus.REJECTED => "bg-danger",
        EQAEnrollmentStatus.CANCELLED => "bg-dark",
        _ => "bg-danger-subtle text-danger"
    };

    private string GetRoundBadgeClass(EQARoundStatus val) => val switch
    {
        EQARoundStatus.CLOSED => "bg-success",
        EQARoundStatus.RESULTS_SUBMITTED => "bg-info",
        EQARoundStatus.IN_PROGRESS => "bg-warning text-dark",
        EQARoundStatus.PLANNED => "bg-secondary",
        EQARoundStatus.INCIDENCE => "bg-danger",
        _ => "bg-light text-dark"
    };

