<Application
    x:Class="QMSFlowDoc.Client.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QMSFlowDoc.Client.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>
            <local:StringVisibilityConverter x:Key="StringVisibilityConverter" />
            <local:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
            <local:PerformanceColorConverter x:Key="PerformanceColorConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
