<Page
    x:Class="QMSFlowDoc.Client.Views.EQARoundDetailsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:QMSFlowDoc.Client.Views"
    xmlns:dto="using:QMSFlowDoc.Shared.DTOs"
    xmlns:converters="using:QMSFlowDoc.Client.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:StringVisibilityConverter x:Key="StringVisibilityConverter" />
        <converters:PerformanceColorConverter x:Key="PerformanceColorConverter" />
        <converters:DoubleDisplayConverter x:Key="DoubleDisplayConverter" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <RelativePanel Grid.Row="0" Margin="0,0,0,24">
            <Button x:Name="BackButton" Click="Back_Click" 
                    RelativePanel.AlignLeftWithPanel="True" RelativePanel.AlignVerticalCenterWithPanel="True">
                <SymbolIcon Symbol="Back" />
            </Button>
            
            <StackPanel RelativePanel.RightOf="BackButton" Margin="12,0,0,0">
                <TextBlock x:Name="RoundTitleText" Text="Ronda EQA" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock x:Name="RoundSubtitleText" Text="Detalles y resultados" Style="{StaticResource BodyTextBlockStyle}" Foreground="Gray" />
            </StackPanel>

            <CommandBar RelativePanel.AlignRightWithPanel="True" Background="Transparent" OverflowButtonVisibility="Collapsed">
                <AppBarButton x:Name="ApproveButton" Icon="Accept" Label="Aprobar Evaluación" Click="ApproveRound_Click" Visibility="Collapsed" />
                <AppBarButton Icon="Add" Label="Nuevo Resultado" Click="AddResult_Click" />
                <AppBarButton Icon="Folder" Label="Abrir Carpeta" Click="OpenFolder_Click" />
                <AppBarButton Icon="Refresh" Label="Actualizar" Click="Refresh_Click" />
            </CommandBar>
        </RelativePanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="350" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Round Info Card -->
            <StackPanel Grid.Column="0" Spacing="12" Margin="0,0,24,0">
                <Grid Padding="16" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Información de la Ronda" FontWeight="Bold" />
                        <MenuFlyoutSeparator />
                        <TextBlock x:Name="SchemeText" Text="Esquema: -" />
                        <TextBlock x:Name="CodeText" Text="Código: -" />
                        <TextBlock x:Name="YearText" Text="Año: -" />
                        <TextBlock x:Name="StatusText" Text="Estado: -" />
                        <TextBlock x:Name="ReviewerText" Text="Revisado por: -" Visibility="Collapsed" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                        <TextBlock x:Name="DeadlineText" Text="Plazo: -" Foreground="Orange" />
                    </StackPanel>
                </Grid>

                <Grid Padding="16" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Notas" FontWeight="Bold" />
                        <TextBlock x:Name="NotesText" Text="Sin notas adicionales." TextWrapping="Wrap" FontSize="12" Foreground="Gray" />
                    </StackPanel>
                </Grid>

                <!-- Evidence Drop Zone -->
                <Grid Height="120" 
                      Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="8"
                      AllowDrop="True" DragOver="Evidence_DragOver" Drop="Evidence_Drop"
                      BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="2">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
                        <FontIcon Glyph="&#xE898;" FontSize="32" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                        <TextBlock Text="Anexar Evidencias" Foreground="{ThemeResource TextFillColorPrimaryBrush}" FontWeight="SemiBold" FontSize="14" TextAlignment="Center" />
                        <TextBlock Text="Arrastra archivos aquí" Foreground="Gray" FontSize="12" TextAlignment="Center" />
                    </StackPanel>
                </Grid>
                
                <Button Content="Cerrar Ronda" x:Name="CloseRoundButton" Click="CloseRound_Click" HorizontalAlignment="Stretch" Style="{StaticResource AccentButtonStyle}" />
            </StackPanel>

            <!-- Results List -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Parámetros Evaluados" Style="{StaticResource SubtitleTextBlockStyle}" Margin="0,0,0,12" />

                <!-- Header Grid (Moved outside ListView) -->
                <Grid Grid.Row="1" Padding="12,8" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="100" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Parámetro" FontWeight="SemiBold" Grid.Column="0" />
                    <TextBlock Text="Resultado" FontWeight="SemiBold" Grid.Column="1" />
                    <TextBlock Text="Objetivo" FontWeight="SemiBold" Grid.Column="2" />
                    <TextBlock Text="Z-Score" FontWeight="SemiBold" Grid.Column="3" />
                    <TextBlock Text="Desempeño" FontWeight="SemiBold" Grid.Column="4" />
                </Grid>

                <ListView x:Name="ResultsList" Grid.Row="2" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="dto:EQARoundResultDto">
                            <Grid Padding="12" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="80" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{x:Bind ParameterName}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Notes}" FontSize="12" Foreground="Gray" Visibility="{x:Bind Notes, Converter={StaticResource StringVisibilityConverter}}" />
                                </StackPanel>
                                
                                <TextBlock Text="{x:Bind ResultValue}" Grid.Column="1" VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind TargetValue}" Grid.Column="2" VerticalAlignment="Center" />
                                <TextBlock Text="{x:Bind ZScore, Converter={StaticResource DoubleDisplayConverter}}" Grid.Column="3" VerticalAlignment="Center" />
                                
                                <Border Grid.Column="4" HorizontalAlignment="Left" Padding="8,4" CornerRadius="4" Background="{x:Bind Performance, Converter={StaticResource PerformanceColorConverter}}">
                                    <TextBlock Text="{x:Bind Performance}" FontSize="11" FontWeight="Bold" Foreground="White" />
                                </Border>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="4">
                                    <Button Click="ReportNC_Click" Tag="{x:Bind}" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Crear No Conformidad">
                                        <SymbolIcon Symbol="Flag" />
                                    </Button>
                                    <Button Click="EditResult_Click" Tag="{x:Bind}" Background="Transparent" BorderThickness="0">
                                        <SymbolIcon Symbol="Edit" />
                                    </Button>
                                    <Button Click="DeleteResult_Click" Tag="{x:Bind}" Background="Transparent" BorderThickness="0" Foreground="Red">
                                        <SymbolIcon Symbol="Delete" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Grid>
    </Grid>
</Page>
