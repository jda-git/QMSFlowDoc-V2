<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="QMSFlowDoc.Client.Views.Dialogs.AddFindingDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Registrar Hallazgo de Auditoría"
    PrimaryButtonText="Añadir"
    CloseButtonText="Cancelar"
    DefaultButton="Primary">

    <StackPanel Spacing="16" MinWidth="400">
        <ComboBox x:Name="TypeCombo" Header="Tipo de Hallazgo" HorizontalAlignment="Stretch" SelectedIndex="0">
            <ComboBoxItem Content="Observación (Oportunidad de mejora)" Tag="OBSERVATION" />
            <ComboBoxItem Content="No Conformidad Menor" Tag="MINOR_NC" />
            <ComboBoxItem Content="No Conformidad Mayor" Tag="MAJOR_NC" />
        </ComboBox>
        
        <TextBox x:Name="IsoRequirementBox" Header="Requisito ISO 15189" PlaceholderText="Ej: 5.3.1 Control de documentos" />
        
        <TextBox x:Name="DescriptionBox" 
                 Header="Descripción del Hallazgo" 
                 PlaceholderText="Detalle lo observado y la evidencia..." 
                 AcceptsReturn="True" 
                 Height="100" 
                 HorizontalAlignment="Stretch"/>
    </StackPanel>
</ContentDialog>
