<ContentDialog
    x:Class="QMSFlowDoc.Client.Views.Dialogs.ResetPasswordDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QMSFlowDoc.Client.Views.Dialogs"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Restablecer Contraseña (Admin)"
    PrimaryButtonText="Restablecer"
    CloseButtonText="Cancelar"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

    <StackPanel Spacing="16" MinWidth="350">
        <TextBlock Text="Advertencia: Esta acción cambiará inmediatamente la contraseña del usuario." 
                   Foreground="DarkOrange" TextWrapping="Wrap" />
        
        <PasswordBox x:Name="NewPasswordBox" Header="Nueva Contraseña" />
        <PasswordBox x:Name="ConfirmPasswordBox" Header="Confirmar Nueva Contraseña" />
        
        <TextBlock x:Name="ErrorTextBlock" Foreground="Red" TextWrapping="Wrap" />
    </StackPanel>
</ContentDialog>
