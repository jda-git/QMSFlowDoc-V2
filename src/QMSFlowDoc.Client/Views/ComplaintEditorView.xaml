<Page
    x:Class="QMSFlowDoc.Client.Views.ComplaintEditorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:QMSFlowDoc.Client.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:QMSFlowDoc.Shared.Models"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <Button Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" Click="Back_Click" Style="{StaticResource DateTimePickerFlyoutButtonStyle}" Margin="-10,0,0,10"/>
            <TextBlock Text="Gestión de Queja (ISO 15189)" Style="{StaticResource TitleTextBlockStyle}"/>
            <TextBlock x:Name="StatusBadge" Text="ESTADO" Foreground="Gray" Style="{StaticResource SubtitleTextBlockStyle}"/>
        </StackPanel>

        <!-- Main Content (Tabs) -->
        <Pivot Grid.Row="1" x:Name="MainPivot">
            
            <!-- Phase 1: Reception & Validation -->
            <PivotItem Header="1. Recepción">
                <ScrollViewer>
                    <StackPanel Spacing="16" MaxWidth="800" HorizontalAlignment="Left">
                        <InfoBar Severity="Informational" Title="ISO 15189 §7.7.2" Message="Registre la queja y determine si está relacionada con las actividades del laboratorio (Sustanciación)." IsOpen="True"/>
                        
                        <TextBox x:Name="SourceBox" Header="Origen / Reclamante" PlaceholderText="Nombre del paciente, médico o entidad"/>
                        
                        <ComboBox x:Name="ClaimantTypeCombo" Header="Tipo de Reclamante" SelectedIndex="0">
                            <ComboBoxItem Content="Paciente" Tag="0"/>
                            <ComboBoxItem Content="Clínico" Tag="1"/>
                            <ComboBoxItem Content="Personal" Tag="2"/>
                            <ComboBoxItem Content="Regulador" Tag="3"/>
                            <ComboBoxItem Content="Otro" Tag="4"/>
                        </ComboBox>

                        <TextBox x:Name="DescriptionBox" Header="Descripción de la Queja" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="100"/>
                        
                        <ComboBox x:Name="CategoryCombo" Header="Categoría">
                             <ComboBoxItem Content="Paciente" Tag="0"/>
                             <ComboBoxItem Content="Clínico" Tag="1"/>
                             <ComboBoxItem Content="Tiempo Respuesta" Tag="2"/>
                             <ComboBoxItem Content="Error Informe" Tag="3"/>
                             <ComboBoxItem Content="Otro" Tag="4"/>
                        </ComboBox>

                        <CheckBox x:Name="SubstantiatedCheck" Content="¿La queja está sustanciada? (Relacionada con el laboratorio)"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <CalendarDatePicker x:Name="ReceiptDatePicker" Header="Fecha Notificación Cliente"/>
                            <TextBox x:Name="ReceiptMethodBox" Header="Método de Notificación" PlaceholderText="Email, Teléfono..." Width="200"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Phase 2: Risk & Investigation -->
            <PivotItem Header="2. Investigación">
                <ScrollViewer>
                    <StackPanel Spacing="16" MaxWidth="800" HorizontalAlignment="Left">
                        <InfoBar Severity="Warning" Title="Evaluación de Riesgo" Message="Determine el impacto clínico. Si es ALTO o CRÍTICO, considere abrir una No Conformidad." IsOpen="True"/>
                        
                        <ComboBox x:Name="ImpactCombo" Header="Impacto Clínico / Seguridad Paciente">
                            <ComboBoxItem Content="Ninguno" Tag="0"/>
                            <ComboBoxItem Content="Bajo" Tag="1"/>
                            <ComboBoxItem Content="Alto" Tag="2"/>
                            <ComboBoxItem Content="Crítico" Tag="3"/>
                        </ComboBox>

                        <Button x:Name="LinkNCButton" Content="Vincular / Crear No Conformidad" Click="LinkNC_Click"/>
                        <TextBlock x:Name="RelatedNCText" Text="Sin NC vinculada" Foreground="Gray"/>

                        <TextBox x:Name="InvestigationBox" Header="Resultados de la Investigación" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="150" PlaceholderText="Describa el análisis realizado..."/>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

            <!-- Phase 3: Actions -->
            <PivotItem Header="3. Acciones">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <CommandBar DefaultLabelPosition="Right" Background="Transparent">
                        <AppBarButton Icon="Add" Label="Nueva Acción" Click="AddAction_Click"/>
                    </CommandBar>

                    <ListView Grid.Row="1" x:Name="ActionsList" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ComplaintAction">
                                <StackPanel Spacing="4" Padding="10">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border CornerRadius="4" Padding="6,2" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                                            <TextBlock Text="{x:Bind ActionType}" Style="{StaticResource CaptionTextBlockStyle}"/>
                                        </Border>
                                        <TextBlock Text="{x:Bind Status}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="Blue"/>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind Description}" TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"/>
                                    <TextBlock Text="{x:Bind DueDate}" Foreground="Gray" Style="{StaticResource CaptionTextBlockStyle}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>

            <!-- Phase 4: Closure -->
            <PivotItem Header="4. Cierre">
                <ScrollViewer>
                    <StackPanel Spacing="16" MaxWidth="800" HorizontalAlignment="Left">
                        <InfoBar Severity="Success" Title="Verificación de Eficacia" Message="El cierre de la queja requiere verificar que las acciones tomadas han sido eficaces." IsOpen="True"/>

                        <TextBox x:Name="ResolutionEvidenceBox" Header="Evidencia de Resolución (Comunicación al Cliente)" PlaceholderText="Pegue aquí el contenido del email o referencia al archivo..." AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>

                        <CalendarDatePicker x:Name="EffectivenessDatePicker" Header="Fecha Verificación Eficacia"/>
                        <TextBox x:Name="EffectivenessNotesBox" Header="Notas de Eficacia" PlaceholderText="¿Por qué consideramos que el problema no recurrirá?" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"/>
                        
                        <Button x:Name="CloseComplaintButton" Content="Cerrar Queja Definitivamente" Style="{StaticResource AccentButtonStyle}" Click="CloseComplaint_Click" Margin="0,20,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </PivotItem>

        </Pivot>

        <!-- Footer Actions -->
        <CommandBar Grid.Row="2" DefaultLabelPosition="Right">
            <AppBarButton Icon="Save" Label="Guardar Cambios" Click="Save_Click"/>
            <AppBarButton Icon="Delete" Label="Eliminar" Click="Delete_Click" Foreground="Red"/>
        </CommandBar>
        
        <TextBlock x:Name="ErrorText" Grid.Row="2" Foreground="Red" VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed"/>
    </Grid>
</Page>
