<Page
    x:Class="QMSFlowDoc.Client.Views.EQAView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:QMSFlowDoc.Client.Views"
    xmlns:dto="using:QMSFlowDoc.Shared.DTOs"
    xmlns:converters="using:QMSFlowDoc.Client.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <converters:IntToVisibilityConverter x:Key="IntToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left Pane: Scheme List -->
        <Grid Grid.Column="0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Padding="12" Spacing="8">
                <TextBlock Text="Control Externo (EQA)" Style="{StaticResource SubtitleTextBlockStyle}" />
                <CommandBar DefaultLabelPosition="Right" Background="Transparent">
                    <AppBarButton Icon="Setting" Label="Configuración" Click="Configuration_Click" />
                </CommandBar>
            </StackPanel>

            <ListView x:Name="SchemeList" 
                      Grid.Row="1" 
                      SelectionChanged="SchemeList_SelectionChanged"
                      Padding="0,0,0,12">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="dto:EQASchemeDto">
                        <Grid Padding="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="4">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{x:Bind ProviderName}" FontSize="12" Foreground="Gray" />
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Matrix}" FontSize="12" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                    <TextBlock Text="•" FontSize="12" Foreground="Gray" />
                                    <TextBlock Text="{x:Bind Periodicity}" FontSize="12" Foreground="Gray" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Right Pane: Details -->
        <Grid Grid.Column="1" x:Name="DetailPane" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Padding="24" Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock x:Name="DetailTitle" Style="{StaticResource TitleTextBlockStyle}" />
                    <TextBlock x:Name="DetailProvider" Style="{StaticResource BodyTextBlockStyle}" Foreground="Gray" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <!-- Actions for Scheme? Maybe Edit via Config, here just view -->
                </StackPanel>
            </Grid>

            <!-- Rounds List -->
            <Grid Grid.Row="1" Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
                    <TextBlock Text="Rondas / Ciclos" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                    <Button Style="{StaticResource AccentButtonStyle}" Click="AddRound_Click">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE710;" FontSize="16" />
                            <TextBlock Text="Registrar Ronda" />
                        </StackPanel>
                    </Button>
                </StackPanel>


                <!-- Header for List -->
                <Grid Grid.Row="1" Padding="12,8" Background="{ThemeResource SystemControlBackgroundChromeMediumLowBrush}">
                     <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Código / Ronda" Grid.Column="0" FontWeight="Bold"/>
                    <TextBlock Text="Fecha" Grid.Column="1" FontWeight="Bold"/>
                    <TextBlock Text="Estado" Grid.Column="2" FontWeight="Bold"/>
                    <TextBlock Text="Notas" Grid.Column="3" FontWeight="Bold"/>
                    <TextBlock Text="Acciones" Grid.Column="4" FontWeight="Bold"/>
                </Grid>

                <ListView x:Name="RoundsList" Grid.Row="2" SelectionMode="Single">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="dto:EQARoundDto">
                            <Grid Padding="12,8" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind RoundCode}" Grid.Column="0" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind local:EQAView.FormatDate(DateReceived)}" Grid.Column="1" />
                                <TextBlock Text="{x:Bind Status}" Grid.Column="2" />
                                <TextBlock Text="{x:Bind Notes}" Grid.Column="3" TextTrimming="CharacterEllipsis" />
                                <Button Grid.Column="4" Content="Ver Resultados" Click="ViewRoundResults_Click" Tag="{x:Bind}" FontSize="12" Padding="8,4" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                
                <TextBlock x:Name="EmptyRoundsText" Grid.Row="2" Text="No hay rondas registradas." 
                           HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray" Visibility="Collapsed" />
            </Grid>
        </Grid>

        <StackPanel Grid.Column="1" x:Name="EmptySelectionPane" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
            <FontIcon Glyph="&#xE7F4;" FontSize="48" Foreground="Gray" />
            <TextBlock Text="Selecciona un esquema para ver sus rondas" Foreground="Gray" FontSize="16" />
        </StackPanel>
    </Grid>
</Page>
